/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(self "https://cdn.moyasar.com"), usb=(), interest-cohort=()
  X-DNS-Prefetch-Control: off
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.moyasar.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.moyasar.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https: http:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.firebaseio.com https://*.googleapis.com https://*.google.com https://api.moyasar.com https://cdn.moyasar.com https://api.authentica.sa https://generativelanguage.googleapis.com https://deltastars.store; frame-src https://cdn.moyasar.com https://www.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://api.moyasar.com; upgrade-insecure-requests;

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-store, no-cache, must-revalidate

/manifest.json
  Cache-Control: no-cache
  Content-Type: application/manifest+json

/service-worker.js
  Cache-Control: no-store
